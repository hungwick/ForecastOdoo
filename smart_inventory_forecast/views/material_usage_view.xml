<odoo>
    <record id="view_material_usage_list" model="ir.ui.view">
        <field name="name">material.usage.list</field>
        <field name="model">material.usage</field>
        <field name="arch" type="xml">
            <list string="Phân tích nguyên liệu">

                <field name="product_id"/>

                <field name="today_qty"/>
                <field name="yesterday_qty"/>
                <field name="trend_day"/>

                <field name="week_qty"/>
                <field name="last_week_qty"/>
                <field name="trend_week"/>

                <field name="month_qty"/>
                <field name="last_month_qty"/>
                <field name="trend_month"/>

            </list>
        </field>
    </record>

    <record id="action_material_usage" model="ir.actions.act_window">
        <field name="name">Phân tích nguyên liệu</field>
        <field name="res_model">material.usage</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_material_usage"
              name="Phân tích nguyên liệu"
              parent="menu_smart_forecast_root"
              action="action_material_usage"/>
</odoo>