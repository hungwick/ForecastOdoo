<odoo>
    <data>
    <record id="view_sales_analytics_graph" model="ir.ui.view">
        <field name="name">sales.analytics.graph</field>
        <field name="model">sales.analytics</field>
        <field name="arch" type="xml">
            <graph string="Xu hướng tiêu thụ" type="bar">

                <field name="product_id" type="row"/>
                <field name="month_qty" type="measure"/>

            </graph>
        </field>
    </record>

    <record id="view_sales_analytics_pivot" model="ir.ui.view">
    <field name="name">sales.analytics.pivot</field>
    <field name="model">sales.analytics</field>
    <field name="arch" type="xml">
        <pivot string="Phân tích chi tiết">

            <field name="product_id" type="row"/>
            <field name="month_qty" type="measure"/>
            <field name="week_qty" type="measure"/>

        </pivot>
    </field>
    </record>

    <record id="action_sales_analytics" model="ir.actions.act_window">
        <field name="name">Phân tích doanh thu</field>
        <field name="res_model">sales.analytics</field>
        <field name="view_mode">list,graph,pivot</field>
    </record>

    </data>
</odoo>