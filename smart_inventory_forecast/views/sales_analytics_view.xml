<odoo>
    <data>
    <record id="view_sales_analytics_list" model="ir.ui.view">
        <field name="name">sales.analytics.list</field>
        <field name="model">sales.analytics</field>
        <field name="arch" type="xml">
            <list string="Phân tích doanh thu">

                <field name="product_id"/>

                <field name="today_qty"/>
                <field name="yesterday_qty"/>
                <field name="trend_day"/>

                <field name="week_qty"/>
                <field name="last_week_qty"/>
                <field name="trend_week"/>

                <field name="month_qty"/>
                <field name="last_month_qty"/>
                <field name="trend_month"/>

            </list>
        </field>
    </record>

    <record id="action_sales_analytics" model="ir.actions.act_window">
        <field name="name">Phân tích doanh thu</field>
        <field name="res_model">sales.analytics</field>
        <field name="view_mode">list</field>
    </record>

    <record id="action_compute_sales" model="ir.actions.server">
        <field name="name">Cập nhật phân tích</field>
        <field name="model_id" ref="model_sales_analytics"/>
        <field name="state">code</field>
        <field name="code">
        model.compute_analytics()
        </field>
    </record>
    <menuitem id="menu_sales_analytics"
              name="Phân tích doanh thu"
              parent="menu_smart_forecast_root"
              action="action_sales_analytics"/>

    <menuitem id="menu_compute_sales"
          name="Cập nhật dữ liệu"
          parent="menu_smart_forecast_root"
          action="action_compute_sales"/>

    </data>
</odoo>